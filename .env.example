# Open Assistant - Bootstrap Configuration
# Copy this file to .env and fill in your values
#
# All other settings can be configured through the Settings UI at /settings

# ============================================================================
# REQUIRED: Database Connection
# ============================================================================
# SQLite (default, simple):
DATABASE_URL=sqlite:///data/assistant.db

# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/assistant

# ============================================================================
# REQUIRED: Encryption Key for Credentials
# ============================================================================
# Generate a new key with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ============================================================================
# DEPLOYMENT: Domain Configuration
# ============================================================================
# Set your domain/URL for production deployments
# Examples:
#   - https://assistant.yourdomain.com
#   - http://localhost:8080 (for local development)
# This is used for CORS, OAuth redirects, and generating absolute URLs
APP_URL=http://localhost:8080

# CORS allowed origins (comma-separated)
# For production, specify your frontend domains
# If not set, defaults to common localhost ports for development
# CORS_ORIGINS=https://assistant.yourdomain.com,https://app.yourdomain.com

# ============================================================================
# OPTIONAL: Auto-migrate existing ENV vars to database
# ============================================================================
# If you have an existing .env with settings, set this to 'true' on first run
# to automatically migrate them to the database. After migration, configure
# everything through the Settings UI.
# AUTO_MIGRATE_SETTINGS=false

# ============================================================================
# OPTIONAL: Temporary Files Directory
# ============================================================================
# Directory for temporary files (documents, downloads, etc.)
# Cleaned up nightly by a system cron job
# TMP_DIR=tmp

# ============================================================================
# OPTIONAL: Cron Job Configuration
# ============================================================================
# Maximum number of cron jobs that can run concurrently
# CRON_MAX_CONCURRENT_JOBS=5

# Maximum time (in seconds) a cron job can run before being cancelled
# CRON_JOB_TIMEOUT_SECONDS=600

# Instance identifier for horizontal scaling
# Auto-detected from hostname if not set
# INSTANCE_ID=instance-1

# ============================================================================
# MANAGED MODE: Open Assistant Platform
# ============================================================================
# When running as a managed instance on the Open Assistant Platform, this key
# is automatically injected at provisioning time. Do NOT set this manually
# for self-hosted deployments. When set, enables the /managed/* endpoints.
# MANAGED_API_KEY=
